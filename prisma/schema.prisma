generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"

}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  name            String?
  avatarUrl       String?
  createdAt       DateTime      @default(now())
  playHistory     PlayHistory[]
  playlists       Playlist[]
}
// 2. The Central Track Database (Saved once, referenced millions of times)
model Track {
  id              String        @id // YouTube Video ID
  title           String
  artist          String
  coverUrl        String?
  durationMs      Int?
  
  playHistory     PlayHistory[]
  playlistTracks  PlaylistTrack[]
}
// 3. User Listening History
model PlayHistory {
  id              String        @id @default(uuid())
  userId          String
  trackId         String
  playedAt        DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  track           Track         @relation(fields: [trackId], references: [id], onDelete: Cascade)
  @@index([userId, playedAt(sort: Desc)])
}
// 4. User Playlists
model Playlist {
  id              String          @id @default(uuid())
  userId          String
  name            String
  coverUrl        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks          PlaylistTrack[]
}
// 5. Tracks inside a Playlist (Optimized to prevent duplicates)
model PlaylistTrack {
  playlistId      String
  trackId         String
  addedAt         DateTime      @default(now())
  position        Int           
  playlist        Playlist      @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track           Track         @relation(fields: [trackId], references: [id], onDelete: Cascade)
  // This prevents the same track from being saved twice in the same playlist
  @@id([playlistId, trackId])
  @@index([playlistId, position])
}